---
import { ClientRouter } from 'astro:transitions'
import katexCSS from 'katex/dist/katex.min.css?url'
import { allLocales, base, defaultLocale, themeConfig } from '@/config'
import { ui } from '@/i18n/ui'
import { getPageInfo } from '@/utils/page'

interface Props {
  postTitle?: string
  postDescription?: string
  postSlug?: string
}

// Props and Language
const { postTitle, postDescription, postSlug } = Astro.props
const { currentLang } = getPageInfo(Astro.url.pathname)
const currentUI = ui[currentLang as keyof typeof ui] ?? {}
const lang = currentLang === defaultLocale ? '' : `${currentLang}/`

// Site Configuration
const { title, subtitle, description, i18nTitle, author, favicon } = themeConfig.site
const { mode: defaultMode, light: { background: lightMode }, dark: { background: darkMode } } = themeConfig.color
const { katex: katexEnabled, reduceMotion } = themeConfig.global
const { verification = {}, twitterID = '', googleAnalyticsID = '', umamiAnalyticsID = '', apiflashKey = '' } = themeConfig.seo ?? {}
const { google = '', bing = '', yandex = '', baidu = '' } = verification
const { customGoogleAnalyticsJS = '', customUmamiAnalyticsJS = '' } = themeConfig.preload ?? {}

// Site Metadata
const metaTheme = defaultMode === 'dark' ? darkMode : lightMode
const siteTitle = i18nTitle ? currentUI.title : title
const siteSubtitle = i18nTitle ? currentUI.subtitle : subtitle
const siteDescription = i18nTitle ? currentUI.description : description

// Page Metadata
const pageTitle = postTitle ? `${postTitle} | ${siteTitle}` : `${siteTitle} - ${siteSubtitle}`
const pageDescription = postDescription || siteDescription
const pageImage = postSlug
  ? new URL(`${base}/og/${postSlug}.png`, Astro.url.origin)
  : apiflashKey
    ? `https://api.apiflash.com/v1/urltoimage?access_key=${apiflashKey}&url=${Astro.url}&format=png&width=1500&height=788&ttl=259200&wait_until=network_idle&no_tracking=true`
    : `https://api.apiflash.com/v1/urltoimage?access_key=02a837b6188f4ba0a7fd9fbeff03a83e&url=https://retypeset.radishzz.cc/${lang}&format=png&width=1500&height=788&ttl=604800&wait_until=network_idle&no_tracking=true`
---

<head>
<!-- Basic Info -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
{favicon.toLowerCase().endsWith('.svg') && <link rel="icon" type="image/svg+xml" href={`${base}${favicon}`} />}
{favicon.toLowerCase().endsWith('.png') && <link rel="icon" type="image/png" href={`${base}${favicon}`} />}
{favicon.toLowerCase().endsWith('.ico') && <link rel="icon" type="image/x-icon" href={`${base}${favicon}`} />}
<title>{pageTitle}</title>
<meta name="description" content={pageDescription} />
<meta name="author" content={author} />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content={metaTheme} />

<!-- Preload -->
<link rel="preload" href={`${base}/fonts/EarlySummer-VF-Split/EarlySummer-VF-Subset.woff2`} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={`${base}/fonts/Snell-Black-SF.woff2`} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={`${base}/fonts/Snell-Bold-SF.woff2`} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={`${base}/fonts/STIX-VF.woff2`} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={`${base}/fonts/STIX-Italic-VF.woff2`} as="font" type="font/woff2" crossorigin />
{katexEnabled && <link rel="stylesheet" href={katexCSS} media="print" onload={`this.media='all'`} />}

<!-- Site Links -->
<link rel="canonical" href={Astro.url} />
<link rel="sitemap" href={`${base}/sitemap-index.xml`} />
<link rel="alternate" href={`${base}/rss.xml`} type="application/rss+xml" title="RSS Feed" />
<link rel="alternate" href={`${base}/atom.xml`} type="application/atom+xml" title="Atom Feed" />
{allLocales.map(lang => (
  <link
    rel="alternate"
    href={`${Astro.url.origin}${base}${lang === defaultLocale ? '' : `/${lang}/`}`}
    hreflang={lang}
  />
))}

<!-- Open Graph -->
<meta property="og:type" content={postTitle ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:image" content={pageImage} />
<meta name="twitter:card" content="summary_large_image" />
{twitterID && <meta name="twitter:site" content={twitterID} />}

<!-- Site Verification -->
{google && <meta name="google-site-verification" content={google} />}
{bing && <meta name="msvalidate.01" content={bing} />}
{yandex && <meta name="yandex-verification" content={yandex} />}
{baidu && <meta name="baidu-site-verification" content={baidu} />}

<!-- Global View Transition -->
<ClientRouter fallback="none" />

<!-- Theme Toggle -->
<script
  is:inline
  define:vars={{
    defaultMode,
    lightMode,
    darkMode,
    reduceMotion,
 }}
>
(function () {
  const THEME_CONTROLLER_KEY = '__themeController'
  const THEME_TOGGLE_SETTLE_MS = 600

  function getThemeController() {
    return window[THEME_CONTROLLER_KEY]
  }

  function getStoredTheme() {
    const theme = localStorage.getItem('theme')
    return theme === 'dark' || theme === 'light' ? theme : null
  }

  function followsSystemTheme() {
    return defaultMode === 'auto' && !getStoredTheme()
  }

  function resolveIsDark() {
    const storedTheme = getStoredTheme()
    if (storedTheme) {
      return storedTheme === 'dark'
    }

    if (defaultMode !== 'auto') {
      return defaultMode === 'dark'
    }

    return window.matchMedia('(prefers-color-scheme: dark)').matches
  }

  function applyTheme(isDark, {
    doc = document,
    persist = false,
    emit = false,
  } = {}) {
    doc.documentElement.classList.toggle('dark', isDark)
    doc.documentElement.style.colorScheme = isDark ? 'dark' : 'light'

    const metaThemeColor = doc.head.querySelector('meta[name="theme-color"]')
    if (metaThemeColor) {
      metaThemeColor.setAttribute('content', isDark ? darkMode : lightMode)
    }

    if (doc !== document) {
      return
    }

    if (persist) {
      localStorage.setItem('theme', isDark ? 'dark' : 'light')
    }

    if (emit) {
      document.dispatchEvent(new CustomEvent('theme-changed', {
        detail: { isDark },
      }))
    }
  }

  function initMotionPref(doc = document) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const supportsViewTransitions = 'startViewTransition' in doc
    const shouldReduceMotion = reduceMotion || prefersReducedMotion || !supportsViewTransitions

    doc.documentElement.classList.toggle('reduce-motion', shouldReduceMotion)
  }

  function isInternalNavigationLink(link) {
    if (link.target && link.target !== '_self') {
      return false
    }

    if (link.hasAttribute('download')) {
      return false
    }

    const href = link.getAttribute('href')
    if (!href || href.startsWith('#')) {
      return false
    }

    const url = new URL(link.href, window.location.href)
    return url.origin === window.location.origin
  }

  function isPlainLeftClick(event) {
    return event.button === 0
      && !event.metaKey
      && !event.ctrlKey
      && !event.shiftKey
      && !event.altKey
  }

  function flushPendingNavigation(controller) {
    if (!controller.pendingNavigationHref) {
      return
    }

    const href = controller.pendingNavigationHref
    controller.pendingNavigationHref = undefined
    window.location.assign(href)
  }

  function finishThemeTransition(controller) {
    controller.isThemeTransitioning = false
    controller.themeTransitionPromise = undefined
    document.documentElement.removeAttribute('data-theme-changing')
    flushPendingNavigation(controller)
  }

  function shouldBypassThemeTransition(controller) {
    const justNavigated = typeof controller.lastNavigationAt === 'number'
      ? Date.now() - controller.lastNavigationAt < THEME_TOGGLE_SETTLE_MS
      : false

    return controller.isPageTransitioning
      || justNavigated
      || document.documentElement.classList.contains('reduce-motion')
      || !document.startViewTransition
  }

  function startThemeToggle() {
    const controller = getThemeController()
    if (!controller || controller.isThemeTransitioning) {
      return
    }

    const nextIsDark = !document.documentElement.classList.contains('dark')

    if (shouldBypassThemeTransition(controller)) {
      applyTheme(nextIsDark, { persist: true, emit: true })
      return
    }

    controller.isThemeTransitioning = true
    controller.pendingNavigationHref = undefined
    document.documentElement.setAttribute('data-theme-changing', '')

    const updateTheme = () => applyTheme(nextIsDark, {
      persist: true,
      emit: true,
    })

    const finished = document.startViewTransition(updateTheme)
      .finished
      .catch(() => {})
      .finally(() => finishThemeTransition(controller))

    controller.themeTransitionPromise = finished
  }

  function handleDocumentClick(event) {
    const target = event.target
    if (!(target instanceof Element)) {
      return
    }

    const controller = getThemeController()
    if (controller?.isThemeTransitioning) {
      const link = target.closest('a[href]')
      if (link instanceof HTMLAnchorElement && isPlainLeftClick(event) && isInternalNavigationLink(link)) {
        event.preventDefault()
        controller.pendingNavigationHref = link.href
        return
      }
    }

    const button = target.closest('#theme-toggle-button')
    if (!button) {
      return
    }

    event.preventDefault()
    startThemeToggle()
  }

  function handleSystemThemeChange(event) {
    if (!followsSystemTheme()) {
      return
    }

    applyTheme(event.matches, { emit: true })
  }

  function handleMotionPrefChange() {
    initMotionPref()
  }

  function handleBeforePreparation() {
    const controller = getThemeController()
    if (controller) {
      controller.isPageTransitioning = true
    }
  }

  function handleBeforeSwap(event) {
    const controller = getThemeController()
    if (controller) {
      controller.isPageTransitioning = true
    }

    const newDocument = event.newDocument
    if (newDocument) {
      applyTheme(resolveIsDark(), { doc: newDocument })
      initMotionPref(newDocument)
    }
  }

  function markNavigationSettled() {
    const controller = getThemeController()
    if (!controller) {
      return
    }

    controller.isPageTransitioning = false
    controller.lastNavigationAt = Date.now()
  }

  function handlePageLoad() {
    markNavigationSettled()
    applyTheme(resolveIsDark())
    initMotionPref()
  }

  function cleanupThemeController(controller) {
    controller.mediaQueryList?.removeEventListener('change', controller.systemThemeHandler)
    controller.motionQueryList?.removeEventListener('change', controller.motionPrefHandler)
    document.removeEventListener('click', controller.documentClickHandler, true)
    document.removeEventListener('astro:before-preparation', controller.beforePreparationHandler)
    document.removeEventListener('astro:before-swap', controller.beforeSwapHandler)
    document.removeEventListener('astro:after-swap', controller.afterSwapHandler)
    document.removeEventListener('astro:page-load', controller.pageLoadHandler)
  }

  const existingController = getThemeController()
  if (existingController) {
    cleanupThemeController(existingController)
  }

  const mediaQueryList = window.matchMedia('(prefers-color-scheme: dark)')
  const motionQueryList = window.matchMedia('(prefers-reduced-motion: reduce)')

  const themeController = {
    mediaQueryList,
    motionQueryList,
    systemThemeHandler: handleSystemThemeChange,
    motionPrefHandler: handleMotionPrefChange,
    documentClickHandler: handleDocumentClick,
    beforePreparationHandler: handleBeforePreparation,
    beforeSwapHandler: handleBeforeSwap,
    afterSwapHandler: markNavigationSettled,
    pageLoadHandler: handlePageLoad,
    isPageTransitioning: false,
    lastNavigationAt: existingController?.lastNavigationAt ?? Date.now(),
    isThemeTransitioning: false,
    themeTransitionPromise: undefined,
    pendingNavigationHref: undefined,
  }

  mediaQueryList.addEventListener('change', handleSystemThemeChange)
  motionQueryList.addEventListener('change', handleMotionPrefChange)
  document.addEventListener('click', handleDocumentClick, true)
  document.addEventListener('astro:before-preparation', handleBeforePreparation)
  document.addEventListener('astro:before-swap', handleBeforeSwap)
  document.addEventListener('astro:after-swap', markNavigationSettled)
  document.addEventListener('astro:page-load', handlePageLoad)

  window[THEME_CONTROLLER_KEY] = themeController

  applyTheme(resolveIsDark())
  initMotionPref()
})()
</script>

<!-- Google Analytics -->
<!-- Define gtag on window object for proper Partytown forwarding -->
<!-- See https://github.com/QwikDev/partytown/issues/382 -->
{googleAnalyticsID && (
  <>
    <script
      is:inline
      type="text/partytown"
      src={customGoogleAnalyticsJS || `https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsID}`}
    />
    <script
      is:inline
      type="text/partytown"
      define:vars={{
        googleAnalyticsID,
        customGoogleAnalyticsJS,
      }}
    >
      window.dataLayer = window.dataLayer || []
      window.gtag = function () {
        // eslint-disable-next-line prefer-rest-params
        dataLayer.push(arguments)
      }
      window.gtag('js', new Date())

      if (customGoogleAnalyticsJS) {
        window.gtag('config', googleAnalyticsID, {
          transport_url: new URL(customGoogleAnalyticsJS).origin,
        })
      }
      else {
        window.gtag('config', googleAnalyticsID)
      }
    </script>
  </>
)}

<!-- Umami Analytics -->
{umamiAnalyticsID && (
  <script
    is:inline
    type="text/partytown"
    src={customUmamiAnalyticsJS || 'https://cloud.umami.is/script.js'}
    data-website-id={umamiAnalyticsID}
  />
)}
</head>
