---
import type { Language } from '@/i18n/config'
import { defaultLocale, moreLocales } from '@/config'
import { getTagPath } from '@/i18n/path'
import Layout from '@/layouts/Layout.astro'
import { getTagTree } from '@/utils/content'

export async function getStaticPaths() {
  type PathItem = {
    params: { tags: string }
    props: { lang: Language }
  }

  const paths: PathItem[] = []

  // Default locale
  paths.push({
    params: { tags: 'tags/' },
    props: { lang: defaultLocale },
  })

  // More locales
  moreLocales.forEach((lang) => {
    paths.push({
      params: { tags: `${lang}/tags/` },
      props: { lang },
    })
  })

  return paths
}

const { lang } = Astro.props as { lang: Language }
const tagTree = await getTagTree(lang)
---

<Layout>
  <div class="uno-decorative-line" />

  <div class="no-heti flex flex-wrap gap-x-2.8 gap-y-3.2">
    {tagTree.map(topTag => (
      <a
        href={getTagPath(topTag.path, lang)}
        class="relative inline-flex items-center border border-secondary/18 rounded-full px-2.8 py-0.6 text-sm c-secondary transition-[colors,border-color] duration-150 ease-out hover:(border-secondary/70 c-primary)"
      >
        {topTag.name}
        <span class="ml-1.4 text-xs c-secondary/80">
          {topTag.count}
        </span>
      </a>
    ))}
  </div>
</Layout>
