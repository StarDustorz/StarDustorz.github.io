---
import type { Language } from '@/i18n/config'
import type { TagNode } from '@/utils/content'
import PostList from '@/components/PostList.astro'
import { allLocales } from '@/config'
import { getLangFromLocale, getLangRouteParam } from '@/i18n/lang'
import { getTagPath } from '@/i18n/path'
import Layout from '@/layouts/Layout.astro'
import { getPostsByTagPath, getTagSupportedLangs, getTagTree } from '@/utils/content'

export async function getStaticPaths() {
  type PathItem = {
    params: { lang?: string, tag: string }
  }

  const paths: PathItem[] = []

  const collectNodes = (nodes: TagNode[], lang: Language) => {
    nodes.forEach((node) => {
      paths.push({
        params: {
          lang: getLangRouteParam(lang),
          tag: node.path.map(seg => encodeURIComponent(seg)).join('/'),
        },
      })

      if (node.children.length > 0)
        collectNodes(node.children, lang)
    })
  }

  for (const lang of allLocales) {
    const tree = await getTagTree(lang)
    collectNodes(tree, lang)
  }

  return paths
}

const tagPath = (Astro.params.tag ?? '')
  .split('/')
  .map(seg => decodeURIComponent(seg))
  .filter(Boolean)
const currentLang = getLangFromLocale(Astro.currentLocale)
const posts = await getPostsByTagPath(tagPath, currentLang)
const tagTree = await getTagTree(currentLang)
const supportedLangs = await getTagSupportedLangs(tagPath)
const currentTopTag = tagPath[0] ?? ''
const currentChildTag = tagPath[1] ?? ''
const currentTopNode = tagTree.find(node => node.path[0] === currentTopTag)
---

<Layout supportedLangs={supportedLangs}>
  <div class="uno-decorative-line" />

  <div class="no-heti flex flex-wrap gap-x-2.8 gap-y-3.2">
    {tagTree.map(topTag => (
      <a
        href={getTagPath(topTag.path, currentLang)}
        class={`relative inline-flex items-center border rounded-full px-2.8 py-0.6 text-sm transition-[colors,border-color] duration-150 ease-out ${
          topTag.path[0] === currentTopTag
            ? 'border-secondary/75 c-primary'
            : 'border-secondary/18 c-secondary hover:(border-secondary/70 c-primary)'
        }`}
      >
        {topTag.name}
        <span class="ml-1.4 text-xs c-secondary/80">
          {topTag.count}
        </span>
      </a>
    ))}
  </div>

  {currentTopNode && currentTopNode.children.length > 0 && (
    <div class="mt-5 border-l border-secondary/20 pl-4">
      <div class="flex flex-wrap gap-x-2.2 gap-y-2.2">
        {currentTopNode.children.map(childTag => (
          <a
            href={getTagPath(childTag.path, currentLang)}
            class={`relative inline-flex items-center border rounded-full px-2.8 py-0.6 text-sm transition-[colors,border-color] duration-150 ease-out ${
              childTag.name === currentChildTag
                ? 'border-secondary/75 c-primary'
                : 'border-secondary/18 c-secondary hover:(border-secondary/70 c-primary)'
            }`}
          >
            {childTag.name}
            <span class="ml-1.4 text-xs c-secondary/80">
              {childTag.count}
            </span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="mt-8.5">
    <PostList
      posts={posts}
      lang={currentLang}
    />
  </div>
</Layout>
